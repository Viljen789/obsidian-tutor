rules_version = '2';

// Every document lives under users/{uid}. A signed-in user may touch ONLY their
// own subtree. Concepts, mastery, and cached explanations are written exclusively
// by Cloud Functions (admin SDK bypasses rules), so a client can never forge a
// mastery score or grade — that logic is server-side and not client-trusted.
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      // Profile + settings: the owner may read and write.
      allow read, write: if isOwner(uid);

      // Concept graph: client reads, only Functions write.
      match /concepts/{conceptId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Learner model: client reads, only Functions write (grading is server-side).
      match /mastery/{conceptId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Cached explanations: client reads, only Functions write.
      match /explanationCache/{key} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Sessions: low-stakes, the owner may read and write.
      match /sessions/{sessionId} {
        allow read, write: if isOwner(uid);
      }

      // Flashcard decks: client reads, only Functions write (generated server-side).
      match /flashcards/{conceptId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Practice-exam history: low-stakes record of a sat exam, owner read/write.
      match /exams/{examId} {
        allow read, write: if isOwner(uid);
      }

      // Activity stats (streak summary): low-stakes, owner read/write.
      match /stats/{docId} {
        allow read, write: if isOwner(uid);
      }

      // Study preferences (exam dates): low-stakes, owner read/write.
      match /prefs/{docId} {
        allow read, write: if isOwner(uid);
      }

      // Cheat sheets: client reads, only Functions write (generated server-side).
      match /cheatsheets/{key} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Mermaid diagrams: client reads, only Functions write.
      match /diagrams/{conceptId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Friends list: owner reads; only Functions write (both sides stay in sync).
      match /friends/{friendUid} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Inbox (incoming shared decks, etc.): owner reads + dismisses; Functions write.
      match /inbox/{itemId} {
        allow read, delete: if isOwner(uid);
        allow create, update: if false;
      }
    }

    // Read-only shared decks: anyone with the link may read; only Functions
    // write (created via the createShare callable). The id is an unguessable
    // random token, so a share is effectively unlisted.
    match /shares/{shareId} {
      allow read: if true;
      allow write: if false;
    }

    // --- Collaboration (Wave 5) -------------------------------------------
    // Public profiles: any signed-in user may read (friend discovery); only
    // Functions write (they mint the unique friendCode + sync name/photo).
    match /profiles/{profileUid} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Friend requests: only the sender or recipient may read; Functions write
    // (so a request / acceptance can't be forged).
    match /friendRequests/{reqId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.fromUid
            || request.auth.uid == resource.data.toUid);
      allow write: if false;
    }

    // Presence: the owner writes their own heartbeat; a user may read their own
    // presence, and that of anyone who lists them as a friend.
    match /presence/{presenceUid} {
      allow read: if request.auth != null
        && (request.auth.uid == presenceUid
            || exists(/databases/$(database)/documents/users/$(presenceUid)/friends/$(request.auth.uid)));
      allow write: if request.auth != null && request.auth.uid == presenceUid;
    }

    // --- Group rooms (Wave 5b) --------------------------------------------
    // A room is readable + updatable by its members (the synced pomodoro, leaving).
    // Creating + joining go through Cloud Functions (unique code + membership
    // integrity), so direct create/delete is closed.
    match /rooms/{roomId} {
      allow read, update: if request.auth != null
        && request.auth.uid in resource.data.members;
      allow create, delete: if false;

      // Room presence: any member reads; a member writes only their own doc.
      match /presence/{memberUid} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.members;
        allow write: if request.auth != null
          && request.auth.uid == memberUid
          && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.members;
      }

      // Room chat: members read; a member may post only as themselves.
      match /messages/{msgId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.members;
        allow create: if request.auth != null
          && request.auth.uid == request.resource.data.uid
          && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.members;
        allow update, delete: if false;
      }
    }
  }
}
