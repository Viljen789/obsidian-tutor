rules_version = '2';

// Every document lives under users/{uid}. A signed-in user may touch ONLY their
// own subtree. Concepts, mastery, and cached explanations are written exclusively
// by Cloud Functions (admin SDK bypasses rules), so a client can never forge a
// mastery score or grade — that logic is server-side and not client-trusted.
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      // Profile + settings: the owner may read and write.
      allow read, write: if isOwner(uid);

      // Concept graph: client reads, only Functions write.
      match /concepts/{conceptId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Learner model: client reads, only Functions write (grading is server-side).
      match /mastery/{conceptId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Cached explanations: client reads, only Functions write.
      match /explanationCache/{key} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Sessions: low-stakes, the owner may read and write.
      match /sessions/{sessionId} {
        allow read, write: if isOwner(uid);
      }

      // Flashcard decks: client reads, only Functions write (generated server-side).
      match /flashcards/{conceptId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Practice-exam history: low-stakes record of a sat exam, owner read/write.
      match /exams/{examId} {
        allow read, write: if isOwner(uid);
      }

      // Activity stats (streak summary): low-stakes, owner read/write.
      match /stats/{docId} {
        allow read, write: if isOwner(uid);
      }

      // Study preferences (exam dates): low-stakes, owner read/write.
      match /prefs/{docId} {
        allow read, write: if isOwner(uid);
      }

      // Cheat sheets: client reads, only Functions write (generated server-side).
      match /cheatsheets/{key} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Mermaid diagrams: client reads, only Functions write.
      match /diagrams/{conceptId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    // Read-only shared decks: anyone with the link may read; only Functions
    // write (created via the createShare callable). The id is an unguessable
    // random token, so a share is effectively unlisted.
    match /shares/{shareId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
