# LOCAL DEV (default): leave VITE_USE_EMULATORS unset or "true" — the app talks
# to the Firebase Emulator Suite with a demo project, no real credentials needed.
#
# PRODUCTION: copy to web/.env, set the flag to false, and paste your Firebase
# web app config (Project settings -> Your apps -> SDK setup and configuration).
VITE_USE_EMULATORS=false
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
