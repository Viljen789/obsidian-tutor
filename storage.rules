rules_version = '2';

// Vault zip uploads live under users/{uid}/uploads/**. Only the owner can
// read/write their own uploads. Cap size to keep costs bounded.
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/{allPaths=**} {
      // Owner may read their own files (uploads + ingested vault image assets).
      // The size guard is write-only — `request.resource` is null on reads.
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 50 * 1024 * 1024;
    }
  }
}
