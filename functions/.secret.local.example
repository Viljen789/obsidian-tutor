# Copy this file to `functions/.secret.local` (gitignored) for LOCAL EMULATOR runs.
# The Firebase emulator reads secret values defined via defineSecret() from here.
#
# Choose a provider with the LLM_PROVIDER env var (default: gemini). Set only the
# key for the provider you use:
#
#   gemini         (default) — Google AI Studio free tier.
#                              Get a free key: https://aistudio.google.com/apikey
#   gemini-vertex            — Vertex AI ($300 credit, NO key — uses the function's
#                              service account). Nothing to set here.
#   anthropic                — Claude. Set ANTHROPIC_API_KEY.
#
# For PRODUCTION, set secrets instead with e.g.:
#   firebase functions:secrets:set GEMINI_API_KEY
# and (to switch providers) set LLM_PROVIDER in functions/.env or the function config.

GEMINI_API_KEY=your-google-ai-studio-key
# ANTHROPIC_API_KEY=sk-ant-your-key-here
